---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, epistemicStatus } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body class="page">
		<Header />
		<main class="animate-in">
			<article>
				<header class="article-header">
					<div class="article-meta">
						<FormattedDate date={pubDate} />
						{updatedDate && (
							<span class="updated">
								Updated <FormattedDate date={updatedDate} />
							</span>
						)}
					</div>
					{epistemicStatus && (
						<span class="epistemic-status">{epistemicStatus}</span>
					)}
					<h1>{title}</h1>
				</header>
				<div class="prose" style="counter-reset: sidenote-counter;">
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		flex: 1;
		max-width: var(--page-width);
		margin: 0 auto;
		padding: 4rem 1.5rem;
	}

	.article-header {
		max-width: var(--content-width);
		margin-bottom: 3rem;
	}

	.article-meta {
		font-family: var(--font-mono);
		font-size: 0.7rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--text-muted);
		margin-bottom: 1rem;
		display: flex;
		gap: 1.5rem;
		align-items: baseline;
	}

	.updated {
		font-style: italic;
		text-transform: none;
		letter-spacing: normal;
	}

	.epistemic-status {
		margin-bottom: 1.5rem;
	}

	h1 {
		font-size: 2.2rem;
		font-weight: 400;
		line-height: 1.2;
		margin: 0;
		max-width: 22ch;
	}

	.prose {
		max-width: var(--content-width);
	}

	.prose :global(p:first-of-type::first-letter) {
		float: left;
		font-size: 3.8em;
		line-height: 0.75;
		padding: 0.06em 0.12em 0 0;
		font-weight: 500;
		color: var(--text);
	}

	.prose :global(h2) {
		margin-top: 3rem;
		margin-bottom: 1rem;
	}

	.prose :global(h3) {
		margin-top: 2rem;
		margin-bottom: 0.75rem;
	}

	.prose :global(ul) {
		padding-left: 1.5rem;
		margin-bottom: 1.5em;
		list-style-type: disc;
	}

	.prose :global(ol) {
		padding-left: 1.5rem;
		margin-bottom: 1.5em;
		list-style-type: decimal;
	}

	.prose :global(li) {
		margin-bottom: 0.5em;
	}

	.prose :global(blockquote) {
		margin-left: 0;
	}

	@media (max-width: 768px) {
		main {
			padding: 3rem 1.5rem;
		}

		h1 {
			font-size: 1.7rem;
		}
	}
</style>
