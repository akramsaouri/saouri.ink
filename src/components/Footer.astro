---
const today = new Date();
---

<footer>
	<span>&copy; {today.getFullYear()}</span>
</footer>

<style>
	footer {
		max-width: var(--page-width);
		margin: 0 auto;
		padding: 4rem 1.5rem 3rem;
		font-family: var(--font-mono);
		font-size: 0.7rem;
		color: var(--text-muted);
		letter-spacing: 0.05em;
	}
</style>
