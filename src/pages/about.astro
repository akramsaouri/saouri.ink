---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`About — ${SITE_TITLE}`} description="About me" />
	</head>
	<body class="page">
		<Header />
		<main class="animate-in">
			<h1>About</h1>
			<div class="prose">
				<p>
					I'm Akram, this is a space where I reflect on ideas and try to express them into words.
				</p>
				<p>
				In times where human-made things are scarce, I believe doing "more human" things is a valuable currency, writing is one of them.
				</p>
				<p>
					Find me on <a href="https://github.com/akramsaouri">GitHub</a>.
				</p>
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	.page {
		min-height: 100vh;
		display: flex;
		flex-direction: column;
	}

	main {
		flex: 1;
		max-width: var(--page-width);
		margin: 0 auto;
		padding: 4rem 1.5rem;
	}

	h1 {
		font-size: 2.2rem;
		font-weight: 400;
		margin-bottom: 2rem;
	}

	.prose {
		max-width: var(--content-width);
	}
</style>
